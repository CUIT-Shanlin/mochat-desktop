# MoChat Desktop 默认连接配置（已指向服务器 103.40.14.14）
# 应用内 “设置 > 连接” 的 localStorage 会覆盖这里的值。

# api-service REST：登录 / 好友 / 群组 / 历史 / 多媒体上传
VITE_API_BASE_URL=http://103.40.14.14:57675

# call-service REST：通话 HTTP 接口
VITE_CALL_BASE_URL=http://103.40.14.14:24478

# call-service WebSocket：通话信令
VITE_CALL_WS_URL=ws://103.40.14.14:24478

# multimedia-service：跟 api-service 同地址
VITE_MEDIA_BASE_URL=http://103.40.14.14:57675

# access-gateway TCP+TLS（聊天长连接，端口 20823，自签证书）
VITE_CHAT_GATEWAY_URL=tls://103.40.14.14:20823

# 后端不可用时是否进入演示模式（用本地数据演示 UI）
VITE_DEMO_MODE=false